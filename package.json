{
  "name": "dokanex",
  "private": true,
  "version": "1.1.0",
  "description": "DokkanX — تطبيق إدارة المنتجات",
  "author": "Ibrahim Baki <ibbaqi@gmail.com>",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "wait-on http://localhost:5173 && electron .",
    "electron:dev": "concurrently -n VITE,ELECTRON -c cyan,green \"npm run dev\" \"npm run electron:start\"",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dexie": "^4.4.3",
    "electron-updater": "^6.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.3",
    "vite-plugin-pwa": "^0.20.5",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.dokkanex.app",
    "productName": "DokkanX",
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs"
    ],
    "extraResources": [
      {
        "from": "public/icons/icon-512.png",
        "to": "icon-512.png"
      }
    ],
    "directories": {
      "output": "dist-electron"
    },
    "publish": {
      "provider": "github",
      "owner": "IbrahimBaki",
      "repo": "Dokkanex"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icons/icon-512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icons/icon-512.png",
      "category": "Office"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icons/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DokkanX"
    }
  }
}
